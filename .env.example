POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change_me

OPENWEBUI_DB_NAME=openwebui_db
OPENWEBUI_DB_USER=openwebui_user
OPENWEBUI_DB_PASSWORD=change_me
OPENWEBUI_DATABASE_URL=postgresql://${OPENWEBUI_DB_USER}:${OPENWEBUI_DB_PASSWORD}@postgres:5432/${OPENWEBUI_DB_NAME}

OPENAI_API_KEY=sk-your-key
LITELLM_API_KEY=sk-your-key
LITELLM_MASTER_KEY=sk-your-master-key
LITELLM_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Model-specific settings (adjust based on model capabilities)
VLLM_SERVED_MODEL=Qwen/Qwen3.5-9B
LITELLM_MODEL_NAME=qwen-3.5-9b
MODEL_MAX_CONTEXT_LEN=262144
MODEL_DEFAULT_MAX_TOKENS=32768
MODEL_DEFAULT_TEMPERATURE=0.6
MODEL_DEFAULT_TOP_P=0.95

# vLLM runtime parameters
VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_MAX_NUM_SEQS=16
VLLM_TOOL_CALL_PARSER=qwen3_coder
VLLM_REASONING_PARSER=qwen3
